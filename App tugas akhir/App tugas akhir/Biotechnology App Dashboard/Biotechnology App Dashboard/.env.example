# Public internet API for mobile data, optional.
# Example: https://your-subdomain.loca.lt/biotech-api
VITE_PUBLIC_API_BASE_URL=

# Android API URL.
# Emulator: http://10.0.2.2/biotech-api
# Physical phone on same Wi-Fi: http://<LAPTOP_IPV4>/biotech-api
VITE_ANDROID_API_BASE_URL=http://<LAPTOP_IPV4>/biotech-api
VITE_ANDROID_API_BASE_URL_FALLBACKS=http://10.0.2.2/biotech-api,http://10.0.3.2/biotech-api

# Homography FastAPI service.
# Emulator: http://10.0.2.2:8000
# Physical phone on same Wi-Fi: http://<LAPTOP_IPV4>:8000
VITE_ANDROID_HOMOGRAPHY_API_BASE_URL=http://<LAPTOP_IPV4>:8000

# YOLO FastAPI service.
# Emulator: http://10.0.2.2:9000
# Physical phone on same Wi-Fi: http://<LAPTOP_IPV4>:9000
VITE_ANDROID_YOLO_API_BASE_URL=http://<LAPTOP_IPV4>:9000

# Optional public YOLO URL, for example ngrok.
VITE_PUBLIC_YOLO_API_BASE_URL=
