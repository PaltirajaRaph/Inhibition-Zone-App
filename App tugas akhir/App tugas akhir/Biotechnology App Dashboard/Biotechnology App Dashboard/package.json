      "scripts": {
            "dev": "vite",
            "build": "vite build",
            "backend:start": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 start",
            "backend:start:force": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 start -ForcePortCleanup",
            "backend:start:noxampp": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 start -SkipXampp",
            "backend:start:noxampp:force": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 start -SkipXampp -ForcePortCleanup",
            "backend:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 stop",
            "backend:stop:noxampp": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 stop -SkipXampp",
            "backend:status": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 status",
            "backend:restart": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 restart",
            "backend:restart:noxampp": "powershell -ExecutionPolicy Bypass -File ./scripts/backend-services.ps1 restart -SkipXampp",
            "api:tunnel": "npx --yes localtunnel --port 80 --local-host 127.0.0.1",
            "api:ngrok": "ngrok http 80",
            "homography:ngrok": "ngrok http 8000",
            "android:sync": "vite build && cap sync android",
            "android": "npm run android:sync && cap open android",
            "android:daily": "powershell -ExecutionPolicy Bypass -File ./scripts/android-daily.ps1",
            "android:daily:noopen": "powershell -ExecutionPolicy Bypass -File ./scripts/android-daily.ps1 -SkipOpen"
      }
