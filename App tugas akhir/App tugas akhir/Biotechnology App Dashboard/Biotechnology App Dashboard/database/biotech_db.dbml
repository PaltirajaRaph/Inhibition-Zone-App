// ============================================================
// TABLE GROUPS (untuk dbdiagram.io layout)
// ============================================================

TableGroup tenant {
  organizations
  organization_admins
  organization_teams
  organization_members
}

TableGroup lab_data {
  analyses
  results
  file_uploads
  antibiotics
}

TableGroup super_admin {
  account_control_credentials
  account_control_audit_logs
}
